<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Calculadora de Crédito Bancário</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: #f4f6f9;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            color: #333;
        }

        .container {
            background-color: #ffffff;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
            width: 100%;
            max-width: 450px;
        }

        h2 {
            color: #1a365d;
            margin-bottom: 20px;
            text-align: center;
            font-size: 1.5rem;
        }

        .tabela-regras {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 25px;
            font-size: 0.85rem;
        }

        .tabela-regras th, .tabela-regras td {
            border: 1px solid #e2e8f0;
            padding: 8px;
            text-align: left;
        }

        .tabela-regras th {
            background-color: #f7fafc;
            color: #4a5568;
        }

        .form-group {
            margin-bottom: 20px;
        }

        label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: #4a5568;
        }

        input[type="number"] {
            width: 100%;
            padding: 12px;
            border: 2px solid #cbd5e0;
            border-radius: 6px;
            font-size: 1rem;
            outline: none;
            transition: border-color 0.2s;
        }

        input[type="number"]:focus {
            border-color: #3182ce;
        }

        button {
            width: 100%;
            background-color: #3182ce;
            color: white;
            border: none;
            padding: 12px;
            border-radius: 6px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.2s;
        }

        button:hover {
            background-color: #2b6cb0;
        }

        .resultado {
            margin-top: 25px;
            padding: 15px;
            border-radius: 6px;
            background-color: #ebf8ff;
            border-left: 4px solid #3182ce;
            display: none;
        }

        .resultado p {
            margin-bottom: 8px;
            font-size: 0.95rem;
        }

        .resultado p:last-child {
            margin-bottom: 0;
        }

        .destaque {
            font-weight: bold;
            color: #2b6cb0;
        }
    </style>
</head>
<body>

<div class="container">
    <h2>Simulador de Crédito Especial</h2>
    
    <table class="tabela-regras">
        <thead>
            <tr>
                <th>Saldo Médio</th>
                <th>Percentual de Crédito</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>Até R$ 200,00</td>
                <td>Nenhum crédito</td>
            </tr>
            <tr>
                <td>De R$ 200,01 a R$ 400,00</td>
                <td>20% do saldo médio</td>
            </tr>
            <tr>
                <td>De R$ 400,01 a R$ 600,00</td>
                <td>30% do saldo médio</td>
            </tr>
            <tr>
                <td>Acima de R$ 600,00</td>
                <td>40% do saldo médio</td>
            </tr>
        </tbody>
    </table>

    <div class="form-group">
        <label for="saldo">Digite o Saldo Médio do Último Ano (R$):</label>
        <input type="number" id="saldo" step="0.01" min="0" placeholder="Ex: 500.50">
    </div>

    <button onclick="calcularCredito()">Calcular Crédito</button>

    <div id="resultado" class="resultado">
        <p><strong>Saldo Médio Informado:</strong> <span id="resSaldo" class="destaque"></span></p>
        <p><strong>Valor do Crédito Concedido:</strong> <span id="resCredito" class="destaque"></span></p>
    </div>
</div>

<script>
    function calcularCredito() {
        // Captura o valor do input
        const saldoInput = document.getElementById('saldo').value;
        
        // Validação simples
        if (saldoInput === '' || saldoInput < 0) {
            alert('Por favor, insira um valor de saldo médio válido.');
            return;
        }

        const saldoMedio = parseFloat(saldoInput);
        let percentual = 0;
        let valorCredito = 0;

        // Lógica de cálculo baseada nas faixas informadas na tabela
        if (saldoMedio <= 200) {
            percentual = 0;
        } else if (saldoMedio <= 400) {
            percentual = 0.20; // 20%
        } else if (saldoMedio <= 600) {
            percentual = 0.30; // 30%
        } else {
            percentual = 0.40; // 40%
        }

        valorCredito = saldoMedio * percentual;

        // Formatação para moeda local (BRL)
        const formatarMoeda = (valor) => {
            return valor.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
        };

        // Exibe os dados na tela
        document.getElementById('resSaldo').innerText = formatarMoeda(saldoMedio);
        document.getElementById('resCredito').innerText = valorCredito > 0 ? formatarMoeda(valorCredito) : 'Nenhum crédito disponível.';
        
        // Torna a div de resultado visível
        document.getElementById('resultado').style.display = 'block';
    }
</script>

</body>
</html>
